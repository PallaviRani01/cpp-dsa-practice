
// reverse array using stack
#include <iostream>
#include <stack>
using namespace std;

int main() {
    int arr[] = {10, 20, 30, 40, 50};
    int n = 5;

    stack<int> s;

    for (int i = 0; i < n; i++)
        s.push(arr[i]);

    while (!s.empty()) {
        cout << s.top() << " ";
        s.pop();
    }
}
