class Solution{
    public:
    bool isValid(string s){
        stack>>char>>s1;
        fo(char ch:s){
            if(ch=='('|| ch=='{' || ch=='[') s1.push(ch);
            else{
                if(!s1.empty() && ((ch==')' && s1.top()=='(')||(ch=']' && s1.top()=='{')||(ch=']' && s1.top()=='['))) s1.top();
                else return false;
            }
        }
        return s1.empty();
    }
}
